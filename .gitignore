# Daten/Anhänge, die nicht hochgeladen werden sollen
attachments_extracted/  # Wichtig: Speichert Ihre extrahierten Anhänge
*.eml                 # Beispiel-E-Mails nicht hochladen, wenn sie private Daten enthalten könnten
*.json                # Analyseergebnisse nicht hochladen
*.log                 # Log-Dateien
*.db                  # Datenbanken

# API-Keys oder sensible Daten (falls später hinzugefügt)
*.env
*.ini
*.key
*.pem
credentials.json